# База данных PostgreSQL
# Для Docker: DB_HOST=postgres (имя сервиса)
# Для локальной разработки: DB_HOST=localhost
DB_HOST=postgres
DB_PORT=5432
DB_USER=weather
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=weather
DB_SSLMODE=disable

# MQTT брокер
MQTT_HOST=192.168.1.7
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC=ecowitt/#
MQTT_CLIENT_ID=weather-consumer

# HTTP сервер (для будущего API)
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# Логирование (debug, info, warn, error)
LOG_LEVEL=info
LOG_FORMAT=text

# Местоположение метеостанции (для расчёта восхода/заката)
LOCATION_LATITUDE=44.995574
LOCATION_LONGITUDE=41.128354
LOCATION_TIMEZONE=Europe/Moscow

# Telegram бот
TELEGRAM_TOKEN=
TELEGRAM_DEBUG=false
TELEGRAM_UPDATE_TIMEOUT=60
TELEGRAM_NOTIFY_INTERVAL=300
# ID админов (chat_id через запятую, для получения своего ID напишите боту /start)
TELEGRAM_ADMIN_IDS=
# Время отправки ежедневной утренней сводки погоды (формат HH:MM)
TELEGRAM_DAILY_SUMMARY_TIME=07:00

# Max бот
MAX_TOKEN=
MAX_DEBUG=false
MAX_UPDATE_TIMEOUT=60
MAX_NOTIFY_INTERVAL=300
# Время отправки ежедневной утренней сводки погоды в Max (формат HH:MM)
MAX_DAILY_SUMMARY_TIME=07:00

# Прогноз погоды (Open-Meteo)
FORECAST_UPDATE_INTERVAL=3600
FORECAST_HOURLY_HOURS=48
FORECAST_DAILY_DAYS=7
FORECAST_API_TIMEOUT=30

# Интеграция с Народным Мониторингом (narodmon.ru)
# Включить/выключить отправку данных на narodmon.ru
NARODMON_ENABLED=false
# MAC-адрес устройства (уникальный идентификатор, можно сгенерировать любой в формате AA:BB:CC:DD:EE:FF)
NARODMON_MAC=AA:BB:CC:DD:EE:FF
# Название устройства (будет отображаться на сайте)
NARODMON_DEVICE_NAME=EcoWitt Метеостанция
# Интервал отправки данных в секундах (минимум 300, рекомендуется 300-600)
NARODMON_INTERVAL=300
# Адрес сервера Narodmon
NARODMON_SERVER=narodmon.ru:8283
# Таймаут подключения в секундах
NARODMON_TIMEOUT=10
# URL страницы устройства на Narodmon (можно указать конкретное устройство по MAC)
NARODMON_DEVICE_URL=https://narodmon.ru/

# Astronomy API (IPGeolocation.io) для точных данных о луне
# Получить бесплатный API ключ: https://ipgeolocation.io/signup.html
ASTRONOMY_API_KEY=
# Таймаут API запросов в секундах
ASTRONOMY_API_TIMEOUT=10

# Геомагнитная активность (xras.ru)
# Включить/выключить сбор данных о Kp-индексе и солнечной активности
GEOMAGNETIC_ENABLED=true
# URL источника JSON с данными по Kp
GEOMAGNETIC_URL=https://xras.ru/txt/kp_PIL9.json
# Интервал опроса в секундах (10800 = 3 часа, совпадает с шагом данных)
GEOMAGNETIC_UPDATE_INTERVAL=10800
# Таймаут HTTP запроса в секундах
GEOMAGNETIC_API_TIMEOUT=30
# Порог индекса Kp для отправки Telegram-алерта (5 = G1, минимальная буря)
GEOMAGNETIC_ALERT_THRESHOLD=5
# Опциональный HTTPS прокси для xras.ru (если сайт недоступен напрямую)
GEOMAGNETIC_HTTPS_PROXY=
